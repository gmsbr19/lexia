# Lexia — environment template. Copy to `.env` and fill in. Validation lives in
# src/lib/env.ts (the app refuses to boot listing any missing/invalid var).

# ── Required ──────────────────────────────────────────────────────────────────

# SQLite database file. Relative paths resolve against the prisma/ folder in
# dev; in production (systemd) use an ABSOLUTE path, e.g.:
#   DATABASE_URL="file:/srv/lexia/prisma/prod.db"
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5) JWT signing secret — at least 32 chars.
# Generate with: openssl rand -base64 33   (or: npx auth secret)
AUTH_SECRET=""

# ── Optional ──────────────────────────────────────────────────────────────────

# Folder containing the unpacked Astrea CSV backup (used by `npm run db:seed`
# and POST /api/financeiro/reimport).
# ASTREA_BACKUP_DIR="C:/path/to/BACKUP_TOTAL_..."

# Genions "Relatório de atendimentos" CSV (used by `npm run db:import:genions`).
# GENIONS_CSV="C:/path/to/relatorio.csv"

# System Chrome/Chromium for PDF generation. On the VPS:
#   apt-get install -y chromium && PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# (also set PUPPETEER_SKIP_DOWNLOAD=1 before `npm ci` there).
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"

# Override the firm's bank info printed in every contract (defaults to the
# value in src/lib/documents/generators/contrato-honorarios/content.ts).
# CONTRATO_BANK_INFO="Banco X, agência 0000, conta 00000-0, em nome de ..."

# Claude API key — enables the LexIA chat (POST /api/lexia/chat). Without it
# the chat answers a friendly 400 telling the operator to configure it.
# ANTHROPIC_API_KEY="sk-ant-..."

# Anthropic ADMIN API key — enables the Configurações → "Consumo (IA)" tab, which
# reads real org-wide API spend from the Admin Cost API. Different from the key
# above; only org admins can mint it in the Console (Settings → Admin keys).
# Requires an organization account (not available on individual accounts).
# ANTHROPIC_ADMIN_KEY="sk-ant-admin01-..."

# ── Notificações por e-mail (canal opcional) ────────────────────────────────────
#
# O sistema de notificações é tempo-real in-app (toast/sino) SEM precisar de e-mail.
# Configure SMTP só se quiser também enviar para o e-mail cadastrado do usuário
# (cada um escolhe em Configurações → Notificações quais módulos recebe por e-mail).
# Sem SMTP, o app funciona 100% e apenas registra em log em vez de enviar.
#
# Base ABSOLUTA do app, usada nos botões/deep-links dos e-mails (sem ela, ou sem
# AUTH_URL, o canal de e-mail fica desabilitado). Também monta o link do convite
# de acesso enviado ao criar um usuário (Configurações → Usuários); sem ela, o
# admin ainda copia o link manualmente (o app usa a origem do request como base).
# APP_BASE_URL="https://lexia.escritorio.com"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"            # "true" para porta 465 (TLS implícito)
# SMTP_USER="no-reply@escritorio.com"
# SMTP_PASS=""
# SMTP_FROM="Lexia <no-reply@escritorio.com>"
#
# ── E-mail via Microsoft Graph (alternativa ao SMTP, p/ Microsoft 365) ──────────
# Em vez de SMTP, o app pode enviar pela API do Microsoft Graph com um token de
# APLICAÇÃO (client credentials). Passos no Entra ID (portal.azure.com):
#   1. App registrations → New registration (single tenant).
#   2. Certificates & secrets → New client secret (copie o VALOR).
#   3. API permissions → Microsoft Graph → Application permissions → Mail.Send →
#      "Grant admin consent". (Opcional: Application Access Policy p/ restringir
#      a quais caixas o app pode enviar.)
#   4. GRAPH_MAIL_SENDER = a caixa remetente (UPN licenciado, ex. no-reply@...).
# Pode reusar o MESMO app das vars ONEDRIVE_* abaixo (basta repetir os valores).
# Seleção do backend: MAIL_PROVIDER=auto usa Graph quando as 4 vars abaixo estão
# setadas; senão cai no SMTP; senão noop (só log). Force com "graph" ou "smtp".
# Ainda precisa de APP_BASE_URL p/ montar os links dos e-mails.
# MAIL_PROVIDER="auto"
# GRAPH_TENANT_ID=""
# GRAPH_CLIENT_ID=""
# GRAPH_CLIENT_SECRET=""
# GRAPH_MAIL_SENDER="no-reply@escritorio.com"

# Onde guardar os anexos da LexIA (imagens/PDF encaminhados no chat).
#   db        → base64 na tabela LexiaAnexo (padrão; nada a configurar)
#   onedrive  → OneDrive do escritório via Microsoft Graph (ESQUELETO — ainda
#               não implementado; preencha as vars abaixo quando for plugar)
# ANEXO_STORAGE="db"
# ONEDRIVE_TENANT_ID=""
# ONEDRIVE_CLIENT_ID=""
# ONEDRIVE_CLIENT_SECRET=""
# ONEDRIVE_DRIVE_ID=""
# ONEDRIVE_FOLDER="LexIA/anexos"

# ── Processos & Casos (módulo de prazos/andamentos) ─────────────────────────────

# Segredo compartilhado que protege o job de notificações (POST /api/jobs/notificacoes).
# O app é request-driven (sem worker); um cron externo chama o endpoint com o header
# `X-Job-Token: <valor>`. Sem esta var, o endpoint do job fica desabilitado (404).
# Ex. crontab (como usuário lexia): 0 7 * * * curl -s -X POST -H "X-Job-Token: $JOBS_TOKEN" https://<dominio>/api/jobs/notificacoes
# JOBS_TOKEN=""

# Margem de segurança padrão (dias úteis antes da data fatal) para novos prazos.
# PRAZO_MARGEM_DIAS="2"

# Antecedência (dias) com que o job de notificações busca prazos/compromissos a vencer.
# NOTIF_ANTECEDENCIA_DIAS="7"

# ── Captura CNJ (fontes públicas gratuitas) ─────────────────────────────────────
#
# DUAS fontes, ambas públicas e gratuitas do CNJ:
#  • Comunica/DJEN (https://comunicaapi.pje.jus.br) → intimações por OAB. É a base
#    de contagem de prazo. NÃO precisa de chave. As OABs do escritório ficam no
#    banco (cadastre na aba Processos → Captura, ou via `npm run cnj:seed:oabs`).
#  • DataJud (https://api-publica.datajud.cnj.jus.br) → capa/andamentos por número
#    CNJ. Metadados defasados (NÃO conta prazo). Exige a chave PÚBLICA abaixo.
#
# Chave PÚBLICA do DataJud, divulgada pelo CNJ na wiki "por transparência"
# (https://datajud-wiki.cnj.jus.br/api-publica/acesso). O CNJ avisa que ela
# "poderá ser alterada a qualquer momento" — se a captura de andamentos passar a
# dar 401, atualize aqui com o valor corrente da wiki. Sem esta var, a captura de
# andamentos (DataJud) fica desabilitada. Valor publicado (jun/2026):
# DATAJUD_API_KEY="cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw=="

# Janela (dias) varrida a cada rodada de captura de intimações no Comunica/DJEN.
# CAPTURA_JANELA_DIAS="7"

# Ex. crontab (cron externo, dias úteis, cedo) — usa o mesmo X-Job-Token:
#   0 7 * * 1-5 curl -s -X POST -H "X-Job-Token: $JOBS_TOKEN" https://<dominio>/api/jobs/captura-intimacoes
#   30 7 * * 1-5 curl -s -X POST -H "X-Job-Token: $JOBS_TOKEN" https://<dominio>/api/jobs/captura-andamentos
