# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Claude Code local settings (machine-specific)
.claude/settings.local.json
.claude/launch.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/templates

# database (sqlite)
/prisma/*.db
/prisma/*.db-journal
*.db-journal

# cnj api recon samples (contêm PII real de intimações — nunca commitar; os
# *.sample.json sintéticos usados pelos testes seguem versionados)
src/lib/processos/cnj/__fixtures__/*.latest.json